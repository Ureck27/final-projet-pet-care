# Database Configuration
MONGO_URI=mongodb+srv://user:password@cluster0.mongodb.net/petcare # MongoDB connection string

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-for-production # Must be long and secure

# Server Configuration
PORT=5000
NODE_ENV=production

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend-url.vercel.app # Your deployed Next.js URL (NO trailing slash)
BACKEND_URL=https://your-backend-url.onrender.com

# Email Configuration (for Nodemailer notifications)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_SERVICE=gmail
ADMIN_EMAIL=admin@petcare.com

# Admin Dashboard URL (For deep linking in emails)
ADMIN_DASHBOARD_URL=https://your-frontend-url.vercel.app/admin-dashboard
